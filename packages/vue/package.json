{
  "name": "@algoux/standard-ranklist-renderer-component-vue",
  "version": "0.6.2",
  "description": "Vue components for Standard Ranklist Renderer Component",
  "license": "MIT",
  "homepage": "https://github.com/algoux/standard-ranklist-renderer-component",
  "repository": {
    "type": "git",
    "url": "https://github.com/algoux/standard-ranklist-renderer-component"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "dev": "vite --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@algoux/standard-ranklist-renderer-component-core": "workspace:*",
    "@algoux/standard-ranklist-renderer-component-styles": "workspace:*",
    "@algoux/standard-ranklist-utils": "^0.3.1"
  },
  "peerDependencies": {
    "@algoux/standard-ranklist": "*",
    "vue": ">=3.4.0"
  }
}
