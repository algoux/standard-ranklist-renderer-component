{
  "name": "@algoux/standard-ranklist-renderer-component-solid",
  "version": "0.5.0",
  "description": "Solid components for Standard Ranklist Renderer Component",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.server.es.js",
      "default": "./dist/index.server.es.js"
    }
  },
  "scripts": {
    "build": "vite build --config vite.config.ts && vite build --config vite.ssr.config.ts",
    "dev": "vite --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@algoux/standard-ranklist-renderer-component-core": "workspace:*",
    "@algoux/standard-ranklist-renderer-component-styles": "workspace:*",
    "@algoux/standard-ranklist-utils": "^0.2.11"
  },
  "peerDependencies": {
    "@algoux/standard-ranklist": "*",
    "solid-js": ">=1.9.0"
  }
}
