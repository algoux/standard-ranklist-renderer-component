{
  "name": "@algoux/standard-ranklist-renderer-component",
  "private": true,
  "description": "Standard Ranklist Renderer Component",
  "version": "0.4.15",
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release:audit": "node ./scripts/audit-release-plan.mjs",
    "build": "pnpm run build:all",
    "build:all": "pnpm run build:styles && pnpm run build:core && pnpm run build:react && pnpm run build:vue && pnpm run build:solid && pnpm run build:svelte && pnpm run build:angular",
    "build:styles": "pnpm --filter @algoux/standard-ranklist-renderer-component-styles build",
    "build:core": "pnpm --filter @algoux/standard-ranklist-renderer-component-core build",
    "build:react": "pnpm --filter @algoux/standard-ranklist-renderer-component-react build",
    "build:vue": "pnpm --filter @algoux/standard-ranklist-renderer-component-vue build",
    "build:solid": "pnpm --filter @algoux/standard-ranklist-renderer-component-solid build",
    "build:svelte": "pnpm --filter @algoux/standard-ranklist-renderer-component-svelte build",
    "build:angular": "pnpm --filter @algoux/standard-ranklist-renderer-component-angular build",
    "dev:react": "pnpm --filter @algoux/standard-ranklist-renderer-component-react dev",
    "dev:vue": "pnpm --filter @algoux/standard-ranklist-renderer-component-vue dev",
    "dev:solid": "pnpm --filter @algoux/standard-ranklist-renderer-component-solid dev",
    "dev:svelte": "pnpm --filter @algoux/standard-ranklist-renderer-component-svelte dev",
    "dev:angular": "pnpm --filter @algoux/standard-ranklist-renderer-component-angular dev",
    "test": "pnpm run test:all-frameworks",
    "test:all-frameworks": "pnpm run test:react && pnpm run test:solid && pnpm run test:svelte && pnpm run test:angular",
    "test:react": "vitest run --config vitest.workspace.ts",
    "test:solid": "vitest run --config vitest.solid.config.ts",
    "test:svelte": "vitest run --config vitest.svelte.config.ts",
    "test:angular": "pnpm --filter @algoux/standard-ranklist-renderer-component-angular test",
    "test:release": "pnpm build:all && pnpm run test:all-frameworks && vitest run --config vitest.release.config.ts",
    "prepublishOnly": "pnpm test:release"
  },
  "author": "bLue",
  "keywords": [
    "standard ranklist",
    "srk",
    "renderer component"
  ],
  "homepage": "https://github.com/algoux/standard-ranklist-renderer-component",
  "repository": {
    "type": "git",
    "url": "https://github.com/algoux/standard-ranklist-renderer-component"
  },
  "devDependencies": {
    "@algoux/standard-ranklist": "0.3.12",
    "@algoux/standard-ranklist-utils": "^0.2.11",
    "@changesets/cli": "^2.31.0",
    "@sveltejs/vite-plugin-svelte": "1.0.0-next.49",
    "@testing-library/react": "^12.1.5",
    "@testing-library/svelte": "5.2.8",
    "@types/classnames": "^2.3.1",
    "@types/color": "^3.0.3",
    "@types/node": "^14.18.22",
    "@types/react": "^16.8.0",
    "@types/react-dom": "^16.8.0",
    "@types/semver": "^7.3.10",
    "@typescript-eslint/eslint-plugin": "^5.10.2",
    "@typescript-eslint/parser": "^5.10.2",
    "@vitejs/plugin-react": "^1.3.2",
    "@vitejs/plugin-vue": "^2.3.4",
    "@vue/test-utils": "^2.4.6",
    "classnames": "^2.3.1",
    "jsdom": "^21.1.2",
    "less": "^4.1.3",
    "prettier": "^2.5.1",
    "react": "^16.9.0",
    "react-dom": "^16.9.0",
    "semver": "^7.3.7",
    "solid-js": "^1.9.12",
    "svelte": "^3.59.2",
    "typescript": "^4.5.5",
    "vite": "^2.9.12",
    "vite-plugin-dts": "^1.4.0",
    "vite-plugin-solid": "2.2.6",
    "vitest": "^0.25.8",
    "vue": "^3.4.38"
  },
  "license": "MIT",
  "srkSupportedVersions": ">=0.3.0 <=0.3.12",
  "packageManager": "pnpm@11.1.3"
}
